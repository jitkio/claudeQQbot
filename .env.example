# ==========================================
# AI Agent Bot 配置
# 复制此文件为 .env 并填写你的信息
# 或运行 node setup.mjs 交互式配置
# ==========================================

# --- AI 模型 ---
# MODEL_PROVIDER 可选值:
#   claude_code       - Claude Code CLI（需要安装 claude 命令行）
#   claude_code_proxy - Claude Code CLI + 代理
#   anthropic         - Anthropic Claude API 直连（走 Agent Engine）
#   openai            - OpenAI 兼容 API（DeepSeek/GPT/通义千问/Moonshot 等）
MODEL_PROVIDER=claude_code
MODEL_NAME=                    # 模型名称，如 deepseek-chat、gpt-4o、claude-sonnet-4-20250514
MODEL_MAX_TOKENS=4096
MODEL_TEMPERATURE=0.7

# --- API Keys（根据 MODEL_PROVIDER 填写对应的）---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=            # Anthropic 自定义地址（代理等）

OPENAI_API_KEY=                # OpenAI / DeepSeek / 通义千问等
OPENAI_BASE_URL=               # 自定义 API 地址
# DeepSeek:  OPENAI_BASE_URL=https://api.deepseek.com
# 通义千问:  OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# Moonshot:  OPENAI_BASE_URL=https://api.moonshot.cn

DEEPSEEK_API_KEY=              # 也可以单独配置 DeepSeek key

# --- QQ Bot（在 https://q.qq.com 创建机器人获取）---
QQ_APP_ID=
QQ_CLIENT_SECRET=

# --- 可选 ---
DEFAULT_USER_OPENID=

# --- 运行参数 ---
MAX_CONCURRENT=2
TASK_TIMEOUT_SEC=600
MSG_MAX_LENGTH=2000
PROGRESS_URL=http://127.0.0.1:3456
