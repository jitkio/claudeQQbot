# ==========================================
# AI Agent Bot 配置
# 复制此文件为 .env 并填写你的信息
# 或运行 node setup.mjs 交互式配置
# ==========================================

# --- AI 模型（当前仅支持 claude_code）---
MODEL_PROVIDER=claude_code
CLAUDE_API_KEY=

# --- QQ Bot（在 https://q.qq.com 创建机器人获取）---
QQ_APP_ID=
QQ_CLIENT_SECRET=

# --- 可选：默认推送用户 ---
DEFAULT_USER_OPENID=

# --- 运行参数 ---
MAX_CONCURRENT=2
TASK_TIMEOUT_SEC=600
MSG_MAX_LENGTH=2000
PROGRESS_URL=http://127.0.0.1:3456

# --- 以下为预留（启用对应模型时填写）---
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GLM_API_KEY=
# MINIMAX_API_KEY=
# QWEN_API_KEY=
# MOONSHOT_API_KEY=
# DOUBAO_API_KEY=
# GEMINI_API_KEY=
