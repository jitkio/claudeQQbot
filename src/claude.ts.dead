import { spawn } from 'child_process'
import { CONFIG } from './config.js'
import { mkdirSync, existsSync, writeFileSync, readFileSync, readdirSync, openSync, closeSync } from 'fs'
import { randomUUID } from 'crypto'

for (const d of [CONFIG.claude.workDir, CONFIG.claude.uploadsDir, CONFIG.claude.outputDir])
  if (!existsSync(d)) mkdirSync(d, { recursive: true })

const SF = '/home/ubuntu/claudeqqbot/sessions.json'
let sessions: Record<string, { uuid: string; created: string }> = {}
try { if (existsSync(SF)) sessions = JSON.parse(readFileSync(SF, 'utf-8')) } catch {}
function save() { try { writeFileSync(SF, JSON.stringify(sessions, null, 2)) } catch {} }

function getSession(k: string): { uuid: string; isNew: boolean } {
  if (sessions[k]) return { uuid: sessions[k].uuid, isNew: false }
  const uuid = randomUUID()
  sessions[k] = { uuid, created: new Date().toISOString() }
  save()
  return { uuid, isNew: true }
}

export function resetSession(k: string) {
  sessions[k] = { uuid: randomUUID(), created: new Date().toISOString() }
  save()
}

export function buildPrompt(text: string, filePaths: string[]): string {
  if (!filePaths.length) return text
  const desc = filePaths.map(fp => {
    const ext = fp.split('.').pop()?.toLowerCase() || ''
    const IMG = ['jpg','jpeg','png','gif','webp','bmp']
    const AUD = ['mp3','wav','ogg','flac','silk','slk','amr','m4a']
    const VID = ['mp4','avi','mkv','mov','webm']
    let type = '文件', hint = '用 Read 工具读取'
    if (IMG.includes(ext)) { type = '图片'; hint = '用 Read 工具读取分析图片内容' }
    else if (AUD.includes(ext)) { type = '语音'; hint = `先执行 node /home/ubuntu/claudeqqbot/tools/audio_transcribe.cjs "${fp}" 转换后分析` }
    else if (VID.includes(ext)) { type = '视频'; hint = `先执行 node /home/ubuntu/claudeqqbot/tools/video_process.cjs "${fp}" 抽帧后分析` }
    else if (ext === 'pdf') { type = 'PDF'; hint = '用 Read 工具读取' }
    return `- [${type}] ${fp}\n  处理方式: ${hint}`
  }).join('\n')
  return `用户发送了文件:\n${desc}\n\n用户消息: ${text || '（请分析上述文件内容）'}`
}

export function detectOutputFiles(resp: string): string[] {
  const files: string[] = []
  const re = /\/home\/ubuntu\/claudeqqbot\/workspace\/(?:output|uploads)\/\S+\.\w+/g
  for (const m of resp.match(re) || []) {
    const c = m.replace(/[。，、；：）\]）}'"]+$/, '')
    if (existsSync(c) && !files.includes(c)) files.push(c)
  }
  return files
}

function run(args: string[]): Promise<string> {
  return new Promise((resolve, reject) => {
    let done = false
    const fin = (fn: Function, v: any) => { if (!done) { done = true; clearTimeout(tm); fn(v) } }
    const devnull = openSync('/dev/null', 'r')
    const proc = spawn('claude', args, { cwd: CONFIG.claude.workDir, env: { ...process.env }, stdio: [devnull, 'pipe', 'pipe'] })
    let out = '', err = ''
    proc.stdout.on('data', d => out += d)
    proc.stderr.on('data', d => err += d)
    proc.on('close', code => { try { closeSync(devnull) } catch {}; code === 0 ? fin(resolve, out.trim() || '（完毕）') : fin(reject, new Error(err.slice(0, 500) || `退出码${code}`)) })
    proc.on('error', e => fin(reject, e))
    const tm = setTimeout(() => { proc.kill('SIGTERM'); setTimeout(() => { try { proc.kill('SIGKILL') } catch {} }, 5000); fin(reject, new Error('超时10分钟')) }, CONFIG.claude.timeoutMs)
  })
}

export async function queryClaudeCode(prompt: string, key: string = 'default'): Promise<string> {
  const { uuid, isNew } = getSession(key)
  const base = ['--dangerously-skip-permissions']
  const t0 = Date.now()
  const el = () => ((Date.now() - t0) / 1000).toFixed(1)

  console.log(`[Claude] [${key}] ${isNew ? '新' : '续'} ${uuid.slice(0, 8)}: ${prompt.slice(0, 60)}`)

  if (!isNew) {
    try {
      const r = await run(['-p', prompt, '--resume', uuid, ...base])
      console.log(`[Claude] 完成 (${el()}s) ${r.length}字`)
      return r
    } catch (e: any) {
      console.warn(`[Claude] resume失败: ${e.message?.slice(0, 80)}, 重建`)
      resetSession(key)
    }
  }

  const { uuid: nid } = getSession(key)
  try {
    const r = await run(['-p', prompt, '--session-id', nid, ...base])
    console.log(`[Claude] 完成 (${el()}s) ${r.length}字`)
    return r
  } catch (e: any) {
    console.warn(`[Claude] session失败: ${e.message?.slice(0, 80)}, 降级`)
    const r = await run(['-p', prompt, ...base])
    console.log(`[Claude] 降级完成 (${el()}s)`)
    return r
  }
}
